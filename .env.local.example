# Local-development env. Copy to .env.local (gitignored) and adjust.
#
# NEXT_PUBLIC_API_MODE controls whether the frontend hits real endpoints or
# uses canned responses from lib/mock-api.ts.
#   mock — no backend / LLM calls; default for Phases 1-6 of the build.
#   real — fetch against NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_API_URL=http://localhost:8000
